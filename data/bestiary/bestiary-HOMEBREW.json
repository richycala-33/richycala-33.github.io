      "trait": [
        {
          "name": "暗杀",
          "entries": [
            "在开始战斗的首个回合，格林对任何未开始其回合的生物发动攻击时，其攻击检定具有优势。刺客对被突袭生物造成的所有伤害均为重击。"
          ]
        },
        {
          "name": "反射闪避",
          "entries": [
            "某个敏捷豁免通过后伤害减半的效应指定刺客为目标时，其豁免成功则不受任何伤害，而豁免失败时则只受一半伤害。"
          ]
        },
        {
          "name": "偷袭",
          "entries": [
            "格林对目标造成伤害时，如果其攻击检定具有优势，或者如果其攻击检定没有劣势且它在该目标身边5尺范围内有一个未处于失能状态的盟友。满足以上条件时，刺客造成额外12 ({@dice 3d6}) 点伤害。（1/回合）"
          ]
        }
      ],
      "action": [
        {
          "name": "多重攻击",
          "entries": [
            "格林发动两次短剑攻击，或两次手弩射击。"
          ]
        },
        {
          "name": "短剑",
          "entries": [
            "{@atk mw} {@hit 6}，触及5尺，单一目标。伤害：6 ({@dice 1d6+3}) 点穿刺伤害。目标必须进行一次 {@dc 15} 体质豁免，豁免失败则受到12 ({@dice 3d6}) 点毒素伤害，豁免成功则伤害减半。"
          ]
        },
        {
          "name": "手弩",
          "entries": [
            "{@atk rw} {@hit 8}，射程30/120尺，单一目标。伤害：6 ({@dice 1d6+3}) 点穿刺伤害，目标必须进行一次 {@dc 15} 体质豁免，豁免失败则受到12 ({@dice 3d6}) 点毒素伤害，豁免成功则伤害减半。"
          ]
        }
      ],
